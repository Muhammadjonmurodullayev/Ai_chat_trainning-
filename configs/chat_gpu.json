{
  "_comment": "Chat model GPU config — Colab T4/V100/A100",
  "model": {
    "embed_dim": 384,
    "num_heads": 8,
    "num_layers": 8,
    "ff_dim": 1536,
    "max_seq_len": 1024,
    "dropout": 0.1
  },
  "training": {
    "epochs": 30,
    "batch_size": 4,
    "learning_rate": 0.0003,
    "weight_decay": 0.05,
    "grad_clip": 1.0,
    "early_stopping_patience": 6,
    "accumulation_steps": 4,
    "warmup_ratio": 0.05,
    "label_smoothing": 0.05,
    "mixed_precision": true,
    "device": "auto"
  },
  "data": {
    "train_path": "data/chat_train.jsonl",
    "val_path": "data/chat_val.jsonl",
    "tokenizer_path": "checkpoints/chat/chat_vocab.model"
  },
  "checkpoint": {
    "save_dir": "checkpoints/chat",
    "save_best": true,
    "save_every_n_epochs": 5,
    "save_every_n_steps": 1000
  }
}
